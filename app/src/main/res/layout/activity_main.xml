<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_root"
    tools:context=".MainActivity">

    <!-- 主滾動視圖 -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp"> <!-- 為底部的導覽列留出空間 -->

            <!-- 1. 精緻頂部標題列 (採用 Immersive 質感) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="24dp"
                android:paddingRight="24dp"
                android:paddingTop="32dp"
                android:paddingBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="智慧海象指南"
                        android:textColor="@color/text_primary"
                        android:textSize="26sp"
                        android:fontFamily="sans-serif-condensed-medium"
                        android:textStyle="bold"
                        android:letterSpacing="-0.02" />

                    <!-- Real-time 膠囊標籤 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:text="REAL-TIME"
                        android:textColor="#1D4ED8"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:letterSpacing="0.1"
                        android:backgroundTint="#00000000" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txt_top_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="即時港區海況觀測 · 守護您的乘船安全"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- 2. 今日搭乘動態與量身提醒 (Immersive 漸層大卡片) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_passenger_advice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@android:color/transparent">

                <!-- 內部視圖採用橫向、垂直混合，提供完美海報感 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:background="@drawable/bg_immersive_gradient">

                    <!-- 動態指示標記 -->
                    <LinearLayout
                        android:id="@+id/layout_risk_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:background="#20FFFFFF"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:id="@+id/img_advice_icon"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@android:drawable/ic_dialog_info"
                            app:tint="#4CAF50"
                            android:contentDescription="Advice Icon"/>

                        <TextView
                            android:id="@+id/txt_risk_level"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="今日適宜航行"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/txt_passenger_advice_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="乘船舒適度與防護等級"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <!-- 面向旅客的防暈、晃動關懷與貼心提醒文字 -->
                    <TextView
                        android:id="@+id/txt_passenger_advice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="今日海象平穩，風浪適中。祝您旅途愉快！"
                        android:textColor="#E2E8F0"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.3" />

                    <!-- 貼心小幫手細部輔助資訊 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:paddingTop="16dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💊"
                            android:textSize="20sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:text="易眩暈旅客建議於登船前30分鐘服用防暈藥，並盡量挑選船尾中後方座位。"
                            android:textColor="#F1F5F9"
                            android:textSize="12sp"
                            android:lineSpacingMultiplier="1.2" />
                    </LinearLayout>

                    <!-- 自訂測站附註 -->
                    <TextView
                        android:id="@+id/txt_advice_station_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="* 評估依據測站: 基隆港 (觀測時間 14:30)"
                        android:textColor="#94A3B8"
                        android:textSize="11sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3. 即時船班時刻與開航狀態 (旅客首要關注的即時表) -->
            <LinearLayout
                android:id="@+id/section_schedules"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp"
                    android:paddingHorizontal="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="即時船班狀態"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/txt_schedule_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="讀取中..."
                        android:textColor="#2563EB"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 自訂美觀搜尋過濾器 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_search_input"
                    android:layout_marginBottom="12dp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="2dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="#64748B"
                        android:contentDescription="Search Icon" />

                    <EditText
                        android:id="@+id/edt_search"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@null"
                        android:hint="搜尋港口、船名或航線 (如小琉球、綠島)"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:textSize="13sp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:inputType="text" />
                </LinearLayout>

                <!-- 船班動態卡片清單容器 (由 Java 程式碼動態生成像 Immersive HTML 的細長陰影排版) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_schedule_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="1dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/border_light"
                    app:cardBackgroundColor="@color/bg_card">

                    <LinearLayout
                        android:id="@+id/container_schedules"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingVertical="4dp" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- 4. 即時港口海況觀測卡片 (切換與科學數據觀測) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_weather_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border_light"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="16dp"
                            android:background="#2563EB" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="即時測站海象詳情"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- 自訂下拉選單區塊 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_weather_cell"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="切換海域測站:"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <Spinner
                            android:id="@+id/spinner_stations"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginStart="8dp"
                            android:spinnerMode="dropdown" />
                    </LinearLayout>

                    <!-- 新潮 Immersive 三欄網格配置 (浪高、風速、陣風...) -->
                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="3"
                        android:alignmentMode="alignBounds"
                        android:columnOrderPreserved="false"
                        android:layout_marginBottom="16dp">

                        <!-- 浪高 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_weather_cell"
                            android:gravity="center"
                            android:paddingVertical="12dp"
                            android:layout_margin="3dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="浪高"
                                android:textColor="@color/text_hint"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/txt_detail_wave"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1.2m"
                                android:textColor="@color/text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <!-- 風速 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_weather_cell"
                            android:gravity="center"
                            android:paddingVertical="12dp"
                            android:layout_margin="3dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="風速"
                                android:textColor="@color/text_hint"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/txt_detail_wind"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="6.5 m/s\n(陣風:9.8)"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <!-- 風向 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_weather_cell"
                            android:gravity="center"
                            android:paddingVertical="12dp"
                            android:layout_margin="3dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="風向"
                                android:textColor="@color/text_hint"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/txt_detail_wind_dir"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="東北風"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <!-- 海溫 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_weather_cell"
                            android:gravity="center"
                            android:paddingVertical="12dp"
                            android:layout_margin="3dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="海面溫度"
                                android:textColor="@color/text_hint"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/txt_detail_temp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="26.4 ℃"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <!-- 潮位 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_weather_cell"
                            android:gravity="center"
                            android:paddingVertical="12dp"
                            android:layout_margin="3dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="觀測潮高"
                                android:textColor="@color/text_hint"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/txt_detail_tide"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.12 m"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <!-- 氣壓 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_weather_cell"
                            android:gravity="center"
                            android:paddingVertical="12dp"
                            android:layout_margin="3dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="測站氣壓"
                                android:textColor="@color/text_hint"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/txt_detail_press"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1011 hPa"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </GridLayout>

                    <!-- 地理座標與同步時間 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingTop="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="4dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="測站位置："
                                android:textColor="@color/text_hint"
                                android:textSize="11sp" />
                            <TextView
                                android:id="@+id/txt_detail_location"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="座標位置載入中"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="觀測時間："
                                android:textColor="@color/text_hint"
                                android:textSize="11sp" />
                            <TextView
                                android:id="@+id/txt_detail_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 5. 系統設定與說明面板 (⚙️ 設定頁面專屬) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_settings_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="24dp"
                android:visibility="gone"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border_light"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="16dp"
                            android:background="#2563EB" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="系統主題切換"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Themes selection buttons in row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="24dp">

                        <Button
                            android:id="@+id/btn_light_mode"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="淺色模式 (Light)"
                            android:textAllCaps="false"
                            android:backgroundTint="#2563EB"
                            android:textColor="#FFFFFF" />

                        <Button
                            android:id="@+id/btn_dark_mode"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="深色模式 (Dark)"
                            android:textAllCaps="false"
                            android:backgroundTint="#475569"
                            android:textColor="#FFFFFF" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="16dp"
                            android:background="#10B981" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="系統架構與說明 (Readme)"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="【當前系統狀況與 README 說明】\n\n本系統為整合中央氣象署觀測 API 與交通部航港 TDX 服務所開發之「海象與客船智聯搭乘導覽系統」，旨在提供旅客即時、高保真之開航及海況安全評估。\n\n📡 【主要系統功能模組】\n1. 今日預警叮嚀：綜合分析浪高、風力、能見度等因子，為輕微/中度/易暈、幼童旅客貼心計算晃動等級與防暈藥用藥叮嚀。\n2. 船班動態看板：支援起迄港模糊搜尋，並將「正常/延誤/停航」高顯度標記。\n3. 即時港區觀測：詳盡地呈現浪高、潮差、風偏速、溫度與海浪體感晃動對照。\n4. 智慧導覽列：透過下方「首頁、船期、海象、設定」靈活切換所屬檢視。\n\n🔗 【數據介接】\n• 中央氣象署 (CWA)：氣象浮標 REST API\n• 交通部航港 TDX：客運輪渡實時調度 API"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 底部常駐 Immersive 導覽與操作區 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@color/bg_card"
        android:clickable="true"
        android:focusable="true">

        <!-- 精緻磨砂質感分隔條 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_light" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <!-- 1. 首頁 (Home 作用) -->
            <LinearLayout
                android:id="@+id/layout_tab_home"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackground">
                <TextView
                    android:id="@+id/tv_tab_home_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏠"
                    android:textSize="20sp" />
                <TextView
                    android:id="@+id/tv_tab_home_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="首頁"
                    android:textColor="#2563EB"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- 2. 船期 -->
            <LinearLayout
                android:id="@+id/layout_tab_schedule"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackground">
                <TextView
                    android:id="@+id/tv_tab_schedule_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅"
                    android:textSize="20sp" />
                <TextView
                    android:id="@+id/tv_tab_schedule_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="船期"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- 3. 更新/同步按鈕 (作為核心 FAB 置於導覽列中間，超棒設計) -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btn_refresh_data"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:backgroundTint="#0061A4"
                app:tint="#FFFFFF"
                app:fabSize="normal"
                android:src="@android:drawable/stat_notify_sync"
                android:contentDescription="Refresh Data Button"
                app:elevation="4dp" />

            <!-- 4. 海象 -->
            <LinearLayout
                android:id="@+id/layout_tab_sea"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackground">
                <TextView
                    android:id="@+id/tv_tab_sea_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌊"
                    android:textSize="20sp" />
                <TextView
                    android:id="@+id/tv_tab_sea_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="海象"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- 5. 設定 -->
            <LinearLayout
                android:id="@+id/layout_tab_settings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackground">
                <TextView
                    android:id="@+id/tv_tab_settings_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚙️"
                    android:textSize="20sp" />
                <TextView
                    android:id="@+id/tv_tab_settings_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="設定"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
